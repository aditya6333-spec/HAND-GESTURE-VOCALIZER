#include <WiFi.h>
#include <AsyncTCP.h>
#include <ESPAsyncWebServer.h>

#include <Wire.h>
#include <MPU6050.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <DFRobotDFPlayerMini.h>

HardwareSerial dfSerial(2);

#define RXD2 16
#define TXD2 17

DFRobotDFPlayerMini dfplayer;

// WIFI
const char* ssid = "ASA";
const char* password = "123456798";

AsyncWebServer server(80);

// OLED
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 32
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

// MPU
MPU6050 mpu;

// FLEX
int flex1 = 34;
int flex2 = 35;

// BUZZER
#define BUZZER_PIN 25
bool emergencyActive = false;

// Calibration
int f1_base = 0;
int f2_base = 0;

// OFFSETS
int offset1 = 10;
int offset2 = 15;

// Filter
float f1_filtered = 0;
float f2_filtered = 0;
float alpha = 0.2;

// Stability
String lastMessage = "";
int stableCount = 0;

// Message tracking
String currentMessage = "I AM FINE";
String lastPlayedMessage = "";

// NON-BLOCKING TIMER
unsigned long lastReadTime = 0;
const int interval = 50;

// SSE for instant updates
AsyncEventSource events("/events");

