void handleRoot(AsyncWebServerRequest *request) {
  request->send(200, "text/html", getHTML());
}

// ---------- FUNCTIONS ----------
int readFlex(int pin) {
  return analogRead(pin);
}

void showMessage(String msg) {
  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);
  display.setTextSize(2);
  display.setCursor(0, 0);
  display.println(msg);
  display.display();
}

// ---------- SETUP ----------
void setup() {
  Serial.begin(115200);

  Wire.begin(21, 22);
  Wire.setClock(100000);

  pinMode(BUZZER_PIN, OUTPUT);
  digitalWrite(BUZZER_PIN, LOW);

  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  showMessage("Connecting");

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(300);
    Serial.print(".");
  }

  Serial.println("\nIP: " + WiFi.localIP().toString());
  showMessage(WiFi.localIP().toString());

  // Web Server
  server.on("/", HTTP_GET, handleRoot);
  
  events.onConnect([](AsyncEventSourceClient *client){
    client->send(currentMessage.c_str(), "message", millis());
  });
  server.addHandler(&events);

  server.begin();

  delay(1500);

  // Calibration
  f1_base = readFlex(flex1);
  f2_base = readFlex(flex2);
  f1_filtered = f1_base;
  f2_filtered = f2_base;

  showMessage("READY");

  mpu.initialize();

  dfSerial.begin(9600, SERIAL_8N1, RXD2, TXD2);
  dfplayer.begin(dfSerial);
  dfplayer.volume(30);
}

// ---------- LOOP ----------
void loop() {
  if (millis() - lastReadTime > interval) {
    lastReadTime = millis();

    int raw1 = readFlex(flex1);
    int raw2 = readFlex(flex2);

    f1_filtered = alpha * raw1 + (1 - alpha) * f1_filtered;
    f2_filtered = alpha * raw2 + (1 - alpha) * f2_filtered;

    bool f1_bent = (f1_filtered < (f1_base - offset1));
    bool f2_bent = (f2_filtered < (f2_base - offset2));

    int16_t ax, ay, az;
    mpu.getAcceleration(&ax, &ay, &az);

    String message = "I AM FINE";

    if (f1_bent && !f2_bent) message = "NEED WATER";
    else if (!f1_bent && f2_bent) message = "NEED FOOD";
    else if (f1_bent && f2_bent) message = "EMERGENCY";
    else {
      if (ax < -9000) message = "LIGHT";
      else if (ax > 9000) message = "FAN";
      else if (ay > 9000) message = "WASHROOM";
    }

    if (message == lastMessage) stableCount++;
    else stableCount = 0;

    if (stableCount >= 3) {

      showMessage(message);

      if (message != currentMessage) {
        currentMessage = message;
        events.send(currentMessage.c_str(), "message", millis());
      }

      if (message != lastPlayedMessage) {
        playVoice(message);
        lastPlayedMessage = message;
        emergencyActive = (message == "EMERGENCY");
      }

      stableCount = 0;
    }

    lastMessage = message;
    digitalWrite(BUZZER_PIN, emergencyActive ? HIGH : LOW);
  }
}

// ---------- VOICE ----------
void playVoice(String msg) {
  if (msg == "NEED WATER") dfplayer.playMp3Folder(1);
  else if (msg == "NEED FOOD") dfplayer.playMp3Folder(2);
  else if (msg == "EMERGENCY") dfplayer.playMp3Folder(3);
  else if (msg == "LIGHT") dfplayer.playMp3Folder(4);
  else if (msg == "FAN") dfplayer.playMp3Folder(5);
  else if (msg == "WASHROOM") dfplayer.playMp3Folder(6);
}
